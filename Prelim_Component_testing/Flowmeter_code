import RPi.GPIO as GPIO
import time
import threading

class FlowSensor:
    def __init__(self, pin):
        self.pin = pin
        self.pulse_count = 0
        self.flow_rate = 0.0
        self.total_volume = 0.0
        
        GPIO.setmode(GPIO.BCM)
        GPIO.setup(self.pin, GPIO.IN, pull_up_down=GPIO.PUD_UP)
        GPIO.add_event_detect(self.pin, GPIO.FALLING, callback=self.pulse_counter)
        
        # Start measurement thread
        self.measuring = True
        self.measurement_thread = threading.Thread(target=self.measure_flow)
        self.measurement_thread.start()
    
    def pulse_counter(self, channel):
        self.pulse_count += 1
    
    def measure_flow(self):
        while self.measuring:
            time.sleep(1)  # Measure every second
            
            # Calculate flow rate: F=(98*Q)±3%, so Q=F/98
            self.flow_rate = self.pulse_count / 98.0  # L/min
            self.total_volume += self.flow_rate / 60.0  # Add to total (L)
            
            print(f"Flow Rate: {self.flow_rate:.5f} L/min")
            print(f"Total Volume: {self.total_volume:.5f} L")
            
            self.pulse_count = 0  # Reset counter

# Usage
sensor = FlowSensor(17)  # GPIO pin 17
