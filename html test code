<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Thermostat UI</title>

<style>
body {
    margin: 0;
    font-family: 'Segoe UI', sans-serif;
    background: #3c465a;
}

/* Main Card */
.container {
    margin: 40px auto;
    width: 90%;
    max-width: 1200px;
    background: #0f2f44;
    border-radius: 40px;
    display: flex;
    padding: 40px;
    color: white;
    box-shadow: 0px 10px 30px rgba(0,0,0,0.4);
}

/* Sidebar */
.sidebar {
    width: 200px;
}

.menu-item {
    display: flex;
    align-items: center;
    gap: 15px;
    margin: 30px 0;
    cursor: pointer;
    font-size: 22px;
}

.submenu {
    margin-left: 40px;
    display: none;
    font-size: 18px;
    opacity: 0.8;
}

.submenu div {
    margin: 10px 0;
    cursor: pointer;
}

/* Circle Display */
.main {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
}

.circle {
    width: 350px;
    height: 350px;
    border: 6px solid rgba(255,255,255,0.7);
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
}

.temp {
    font-size: 90px;
}

.subtext {
    font-size: 24px;
    margin-top: 10px;
    opacity: 0.8;
}

/* Toggle styles */
.toggle {
    color: #4fd1c5;
}

</style>
</head>

<body>

<div class="container">

    <!-- Sidebar -->
    <div class="sidebar">

        <div class="menu-item" onclick="goHome()">🏠 Home</div>

        <div class="menu-item" onclick="toggleMenu('modeMenu')">❄️ Mode</div>
        <div id="modeMenu" class="submenu">
            <div onclick="setMode('Smart')">Smart</div>
            <div onclick="setMode('Manual')">Manual</div>
        </div>

        <div class="menu-item" onclick="toggleFan()">🌬️ Fan: <span id="fanState">OFF</span></div>

        <div class="menu-item" onclick="toggleMenu('mainMenu')">☰ Menu</div>
        <div id="mainMenu" class="submenu">
            <div onclick="goTo('data')">Data Analysis</div>
            <div onclick="goTo('system')">System Overview</div>
        </div>

    </div>

    <!-- Main Display -->
    <div class="main">
        <div class="circle">
            <div class="temp" id="tempDisplay">24°C</div>
            <div class="subtext">Currently</div>
        </div>
    </div>

</div>

<script>

// Toggle dropdowns
function toggleMenu(id) {
    let menu = document.getElementById(id);
    menu.style.display = (menu.style.display === "block") ? "none" : "block";
}

// Navigation placeholders
function goHome() {
    alert("Go to Home Page");
    // window.location.href = "/";
}

function goTo(page) {
    alert("Navigate to " + page);
    // window.location.href = "/" + page;
}

// Mode selection
function setMode(mode) {
    alert("Mode set to " + mode);
    // send to backend later
}

// Fan toggle
let fanOn = false;

function toggleFan() {
    fanOn = !fanOn;
    document.getElementById("fanState").innerText = fanOn ? "ON" : "OFF";

    if (fanOn) {
        document.getElementById("fanState").classList.add("toggle");
    } else {
        document.getElementById("fanState").classList.remove("toggle");
    }

    // send to backend later
}

</script>

</body>
</html>
